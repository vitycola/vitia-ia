# Anthropic LLM — required when LLM_PROVIDER=anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase project URL — e.g. https://<project-id>.supabase.co
SUPABASE_URL=https://<project-id>.supabase.co

# Supabase anonymous (public) API key — safe to use in client-side code
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# JWKS endpoint used to verify Supabase-issued JWTs
# Format: https://<project-id>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://<project-id>.supabase.co/auth/v1/.well-known/jwks.json

# Comma-separated list of allowed CORS origins — required in production
# Example: https://vitia.app,https://www.vitia.app
ALLOWED_ORIGINS=http://localhost:3000
